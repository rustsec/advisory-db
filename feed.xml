      &lt;dd&gt;
        &lt;ul&gt;
        
          &lt;li&gt;
            &lt;a href=&quot;https://codeberg.org/1millibyte/toolsnt/issues/18&quot;&gt;
              https://codeberg.org/1millibyte/toolsnt/issues/18
            &lt;/a&gt;
          &lt;/li&gt;
        
        
        &lt;/ul&gt;
      &lt;/dd&gt;
      

      

      
      

      &lt;dt id=&quot;patched&quot;&gt;Patched&lt;/dt&gt;
      &lt;dd&gt;
        
        &lt;ul&gt;
          
          &lt;li&gt;&lt;code&gt;&amp;#62;=0.2.1&lt;/code&gt;&lt;/li&gt;
          
